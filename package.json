{
  "name": "sparrowdesk-chat",
  "private": true,
  "type": "module",
  "description": "SparrowDesk Chat Widget — React, Vue, Solid, and more.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparrowdesk/chat.git"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" run build",
    "dev": "pnpm --filter @sparrowdesk/react-chat run dev",
    "play": "pnpm --filter example-react run dev",
    "test": "pnpm --filter \"./packages/**\" run test",
    "test:prepare": "pnpm --filter @sparrowdesk/react-chat exec playwright install chromium",
    "typecheck": "pnpm --filter \"./packages/**\" run typecheck",
    "release": "pnpm --filter @sparrowdesk/react-chat run release"
  },
  "packageManager": "pnpm@10.0.0"
}